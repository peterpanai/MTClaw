{
  "id": "fr-tools",
  "name": "Function Router Tools",
  "description": "Registers Function Router tools for OpenClaw-side execution",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "rootDir": {
        "type": "string",
        "default": ""
      },
      "routerUrl": {
        "type": "string",
        "default": ""
      },
      "execTimeoutMs": {
        "type": "number",
        "default": 300000
      }
    }
  }
}
