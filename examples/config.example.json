{
  "listen_host": "0.0.0.0",
  "listen_port": 18790,
  "tools_base_dir": "~/.function-router/scripts",
  "fr_completion_check": {
    "enabled": true,
    "mode": "permissive",
    "always_true": false
  },
  "fr_context_history": {
    "enabled": true
  },
  "fr_context_preserve": {
    "enabled": false
  },
  "delegate_tools_to_openclaw": {
    "enabled": true
  },
  "routing": {
    "base_url": "https://api.example.com/v1",
    "model": "your-tool-calling-model",
    "api_key": "${ROUTING_API_KEY}"
  },
  "upstream": {
    "base_url": "https://api.openai.com/v1",
    "api_key": "",
    "model": "gpt-4o"
  },
  "functions_file": "functions.jsonl",
  "scripts_dir": "scripts",
  "max_tool_rounds": 6,
  "tool_exec_timeout_s": 30,
  "routing_timeout_s": 10.0,
  "debug_logging": {
    "enabled": false
  }
}
